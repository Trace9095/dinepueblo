# Neon PostgreSQL (get from Vercel Storage dashboard)
DATABASE_URL=postgresql://user:password@host/dinepueblo?sslmode=require

# JWT secret (generate: openssl rand -base64 32)
JWT_SECRET=your-secret-here

# App URL
NEXT_PUBLIC_APP_URL=https://dinepueblo.com

# Stripe live keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Resend
RESEND_API_KEY=re_...
AUTH_FROM_EMAIL=noreply@dinepueblo.com
NOTIFICATION_EMAIL=CEO@epicai.ai
